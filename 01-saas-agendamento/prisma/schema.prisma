generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("admin")
  clients      Client[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String
  notes        String?
  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([ownerId])
}

model Appointment {
  id          String   @id @default(cuid())
  title       String
  startAt     DateTime
  endAt       DateTime
  status      String   @default("confirmed")
  notes       String?
  ownerId     String
  clientId    String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([clientId])
  @@index([startAt])
}
